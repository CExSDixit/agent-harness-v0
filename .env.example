# Agent Harness v0 — Environment Configuration
# Copy this file to .env and edit with your paths, then `source .env`

# Required: path to your context/notes repo (mounted at /cookbooks in container)
# This is where specs, review reports, and prompts live.
COOKBOOKS_PATH=~/git/my-context-repo

# Default project for tests and when --project is omitted (optional)
# This should be a project name that exists under */projects/ in your cookbooks repo.
# TEST_PROJECT=my-project
# TEST_SPEC=my-spec.md
# TEST_SPEC_RELATIVE=subdir/my-spec.md

# GitHub App credentials (for git push/pull over HTTPS and gh CLI)
# See README.md "GitHub App Setup" for how to create these.
# GITHUB_APP_ID=123456
# GITHUB_APP_INSTALLATION_ID=12345678
# GITHUB_APP_PEM=~/.config/harness/github-app.pem

# Claude Code auth token (run `claude setup-token` on host to generate)
# Required because Claude Code stores OAuth tokens in the macOS Keychain,
# which is not available inside Docker containers.
# WARNING: This is a real credential. Never commit .env to version control.
# If exposed, regenerate immediately with `claude setup-token`.
# CLAUDE_CODE_OAUTH_TOKEN=sk-ant-oat01-...

# Codex auth (if using codex agent)
# Codex stores OAuth tokens in ~/.codex/auth.json (file-based, not Keychain).
# The harness mounts this file read-write so token refresh works inside the container.
# Authenticate on the host first: run `codex` and complete login.
# For OAuth MCP servers, run `codex mcp login <server-name>` on host first.
# OPENAI_API_KEY=sk-...
